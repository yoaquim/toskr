<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
    <interface>
        <field id="selectedMode" type="string" value="" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#ffffff" />

        <!-- Logo centered -->
        <Poster id="logo"
                translation="[810, 140]"
                width="300"
                height="120"
                uri="pkg:/images/toskr.png" />

        <!-- Tagline -->
        <Label id="tagline"
               text="Search streams by..."
               font="font:MediumSystemFont"
               color="#904010"
               horizAlign="center"
               width="1920"
               translation="[0, 290]" />

        <!-- Favorites banner -->
        <Poster id="cardFavorites"
                translation="[660, 360]"
                width="600"
                height="120"
                opacity="0.4"
                uri="pkg:/images/favorites.png" />

        <!-- Three cards centered -->
        <LayoutGroup id="cardRow"
                      translation="[960, 510]"
                      layoutDirection="horiz"
                      horizAlignment="center"
                      itemSpacings="[60]">

            <Poster id="cardCountry"
                    width="280"
                    height="280"
                    opacity="1.0"
                    uri="pkg:/images/country.png" />

            <Poster id="cardSurf"
                    width="280"
                    height="280"
                    opacity="0.4"
                    uri="pkg:/images/surf.png" />

            <Poster id="cardRadio"
                    width="280"
                    height="280"
                    opacity="0.4"
                    uri="pkg:/images/radio.png" />
        </LayoutGroup>

        <!-- Hints: icon + label centered -->
        <LayoutGroup translation="[960, 840]"
                      layoutDirection="horiz"
                      horizAlignment="center"
                      itemSpacings="[40]">
            <!-- Navigate -->
            <Group>
                <Poster translation="[40, 0]" width="36" height="36" uri="pkg:/images/left.png" />
                <Poster translation="[80, 0]" width="36" height="36" uri="pkg:/images/right.png" />
                <Poster translation="[0, 0]" width="36" height="36" uri="pkg:/images/up.png" />
                <Poster translation="[120, 0]" width="36" height="36" uri="pkg:/images/down.png" />
                <Label translation="[0, 42]" width="156" horizAlign="center"
                       font="font:SmallBoldSystemFont" color="#904010" text="Navigate" />
            </Group>
            <!-- Select -->
            <Group>
                <Poster translation="[42, 0]" width="36" height="36" uri="pkg:/images/ok.png" />
                <Label translation="[0, 42]" width="120" horizAlign="center"
                       font="font:SmallBoldSystemFont" color="#904010" text="Select" />
            </Group>
        </LayoutGroup>
    </children>

    <script type="text/brightscript" uri="HomeScene.brs" />
</component>
