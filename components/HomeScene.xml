<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Scene">
    <interface>
        <field id="selectedMode" type="string" value="" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle width="1920" height="1080" color="#ffffff" />

        <!-- Logo centered -->
        <Poster id="logo"
                translation="[810, 100]"
                width="300"
                height="120"
                uri="pkg:/images/toskr.png" />

        <!-- Tagline -->
        <Label id="tagline"
               text="Search streams by..."
               font="font:MediumSystemFont"
               color="#904010"
               horizAlign="center"
               width="1920"
               translation="[0, 250]" />

        <!-- 2x2 grid centered -->
        <Group translation="[610, 310]">
            <!-- Row 1 -->
            <Poster id="cardCountry"
                    translation="[0, 0]"
                    width="280"
                    height="280"
                    opacity="1.0"
                    uri="pkg:/images/country.png" />
            <Poster id="cardSurf"
                    translation="[340, 0]"
                    width="280"
                    height="280"
                    opacity="0.4"
                    uri="pkg:/images/surf.png" />
            <!-- Row 2 -->
            <Poster id="cardFavorites"
                    translation="[0, 340]"
                    width="280"
                    height="280"
                    opacity="0.4"
                    uri="pkg:/images/favorites.png" />
            <Poster id="cardRadio"
                    translation="[340, 340]"
                    width="280"
                    height="280"
                    opacity="0.4"
                    uri="pkg:/images/radio.png" />
        </Group>

        <!-- Hints -->
        <LayoutGroup translation="[960, 960]"
                      layoutDirection="horiz"
                      horizAlignment="center"
                      itemSpacings="[40]">
            <Group>
                <Poster translation="[40, 0]" width="36" height="36" uri="pkg:/images/left.png" />
                <Poster translation="[80, 0]" width="36" height="36" uri="pkg:/images/right.png" />
                <Poster translation="[0, 0]" width="36" height="36" uri="pkg:/images/up.png" />
                <Poster translation="[120, 0]" width="36" height="36" uri="pkg:/images/down.png" />
                <Label translation="[0, 42]" width="160" horizAlign="center"
                       font="font:SmallBoldSystemFont" color="#904010" text="Navigate" />
            </Group>
            <Group>
                <Poster translation="[52, 0]" width="36" height="36" uri="pkg:/images/ok.png" />
                <Label translation="[0, 42]" width="140" horizAlign="center"
                       font="font:SmallBoldSystemFont" color="#904010" text="Select" />
            </Group>
        </LayoutGroup>
    </children>

    <script type="text/brightscript" uri="HomeScene.brs" />
</component>
