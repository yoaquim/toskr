<?xml version="1.0" encoding="utf-8" ?>
<component name="ChannelRow" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="focusPercent" type="float" onChange="onFocusChanged" />
    </interface>
    <children>
        <Rectangle id="rowBg" width="860" height="56" color="#ffffff" />
        <Rectangle id="focusBg" width="860" height="56" color="#f07020" visible="false" />
        <Rectangle id="accentBar" width="4" height="56" color="#f07020" visible="false" />
        <Label id="nameLabel"
               translation="[20, 14]"
               font="font:SmallSystemFont"
               color="#704020"
               width="760" />
        <Poster id="favIcon"
                translation="[815, 10]"
                width="24"
                height="30"
                uri=""
                visible="false" />
    </children>
    <script type="text/brightscript" uri="ChannelRow.brs" />
</component>
